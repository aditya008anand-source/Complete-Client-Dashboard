{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/sheet",
      "destination": "/api/sheet.js"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ],
  "functions": {
    "api/sheet.js": {
      "maxDuration": 10
    }
  }
}
